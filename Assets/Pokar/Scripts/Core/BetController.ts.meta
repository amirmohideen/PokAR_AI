  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color:#60A5FA;\">BetController — stack chips to bet</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @input SceneObject betChip {"hint":"Draggable bet chip (handle) with an InteractableManipulation component."}'
    - '// @input Asset.ObjectPrefab chipPrefab {"hint":"Chip visual prefab cloned to build the stack (no interaction needed)."}'
    - "// @input float chipScale = 2 {\"hint\":\"Uniform local scale applied to each instantiated stack chip (overrides the prefab's baked scale).\"}"
    - '// @ui {"widget":"separator"}'
    - '// @input float creditsPerChip = 10 {"hint":"Credits each stacked chip is worth."}'
    - '// @input float dragStepCm = 2 {"hint":"Centimetres of upward pull needed to add one chip."}'
    - '// @input float chipSpacing = 0.6 {"hint":"Vertical spacing between stacked chips (cm)."}'
    - '// @input float maxChips = 30 {"hint":"Maximum chips that can be stacked in one bet."}'
    - '// @ui {"widget":"separator"}'
    - '// @input SceneObject potAnchor {"hint":"Target the staged chips fly to on Raise/Call (place an empty SceneObject near the pot prefab)."}'
    - '// @input float flyDuration = 0.45 {"hint":"Seconds for a chip to fly to the pot."}'
    - '// @input float flyArc = 3 {"hint":"Arc height of the chip toss (cm). 0 = straight line."}'
